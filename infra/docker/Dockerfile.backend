FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# System deps:
#   - build-essential/curl: build asyncpg/bcrypt-style deps + healthcheck
#   - libpango/cairo/gdk-pixbuf + fonts-noto-cjk: WeasyPrint PDF export (v0.5),
#     with CJK fonts so Chinese resumes render correctly.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl \
    libpango-1.0-0 libpangocairo-1.0-0 libcairo2 libgdk-pixbuf-2.0-0 \
    libffi-dev fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

# Copy backend sources first (hatchling needs the app/ package tree at install time).
COPY backend /app

# Install with the [pdf] extra so PDF export works inside the image.
RUN pip install --upgrade pip && pip install -e ".[pdf]"

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -fsS http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
