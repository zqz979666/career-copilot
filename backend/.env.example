# ===== App =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000

# ===== Security =====
# openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-32-byte-hex-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://career:career@localhost:5432/career_copilot
DATABASE_ECHO=false

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM (Anthropic Claude) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_DEFAULT_MODEL=claude-sonnet-4-5
# Lightweight model for Master Agent intent classification (rule-miss fallback).
LLM_INTENT_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ===== Vision (screenshot OCR via Claude Vision) =====
VISION_MODEL=claude-sonnet-4-5
VISION_MAX_IMAGE_BYTES=5242880     # 5 MB

# ===== Speech-to-Text (OpenAI Whisper) + Embeddings =====
# OPENAI_API_KEY powers both voice transcription and profile embeddings.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=zh                # optional; leave blank for auto-detect

# ===== Embeddings (Profile semantic search via pgvector) =====
# When OPENAI_API_KEY is empty or EMBEDDING_ENABLED=false, the Profile Engine
# degrades to keyword/recency retrieval and stores NULL embeddings.
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ===== Resume Studio =====
RESUME_MAX_VERSIONS=20             # max saved resume versions per user
RESUME_RETRIEVAL_TOP_K=40         # profile entries fed to the Resume Agent

# ===== Document Parsing =====
# Max upload size (bytes). 10 MB by default.
DOCUMENT_MAX_UPLOAD_BYTES=10485760
# Max characters passed to the LLM after extraction.
DOCUMENT_MAX_CHARS=20000

# ===== Rate Limiting =====
RATE_LIMIT_ANON_PER_HOUR=5
RATE_LIMIT_USER_PER_HOUR=60

# ===== v0.8 GitHub OAuth + Webhooks =====
# Register a GitHub OAuth App at: https://github.com/settings/developers
# Callback URL must match GITHUB_OAUTH_REDIRECT_URI below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Scopes: read:user for /user, user:email for verified email, repo for private-PR metadata.
# Downgrade to "read:user user:email public_repo" if you only care about public PRs.
GITHUB_OAUTH_SCOPES=read:user user:email repo
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/github/callback
# The shared secret configured in the GitHub webhook UI (Settings → Webhooks).
# Used for X-Hub-Signature-256 HMAC verification. Empty → all webhooks rejected.
GITHUB_WEBHOOK_SECRET=
# GitHub API base — override for GHES / self-hosted.
GITHUB_API_BASE=https://api.github.com
# Cap how many PRs a single manual sync pulls.
GITHUB_SYNC_MAX_PRS=30
# PR body is truncated to this many chars before it reaches the DB (data minimization).
GITHUB_PR_BODY_MAX_CHARS=500

# ===== v0.8 Integration Token Encryption =====
# Fernet key (urlsafe base64, 32 bytes) used to encrypt OAuth access/refresh tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When blank we DERIVE a stable dev key from JWT_SECRET_KEY — DO NOT rely on this in production.
INTEGRATION_ENCRYPTION_KEY=

# ===== v0.8 Master Agent — parallel dispatch =====
# When true, Master Agent may fan out one primary + several secondary
# sub-agents in parallel (asyncio.gather). Set false to disable and fall back
# to single-agent behavior.
MASTER_PARALLEL_ENABLED=true
